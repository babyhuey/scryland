# Scryland configuration. Copy to `.env` and fill in the values you need.
# All settings are optional unless noted. Values here are defaults.

# -----------------------------
# TCGPlayer (browser automation)
# -----------------------------
# SCRYLAND_HEADLESS=false
# SCRYLAND_BROWSER_TIMEOUT_MS=120000
# SCRYLAND_SLOW_MO_MS=100

# Passphrase for the stored TCGPlayer credential file. Set to skip prompts.
# SCRYLAND_PASSPHRASE=your-passphrase

# Pricing guardrails
# SCRYLAND_MAX_PRICE_CHANGE_PCT=10.0       # prompt above this drop pct
# SCRYLAND_MIN_PRICE_FLOOR=0.25

# Human-like delays between actions. Set no_delays=true for a fast, less
# human-like session (still has real waits for page load, etc.).
# SCRYLAND_MIN_ACTION_DELAY_MS=500
# SCRYLAND_MAX_ACTION_DELAY_MS=2000
# SCRYLAND_NO_DELAYS=false

# Logging
# SCRYLAND_LOG_LEVEL=INFO
# SCRYLAND_LOG_FILE=

# Local DB
# SCRYLAND_DB_PATH=.scryland_inventory.db


# =====================================================================
# eBay (OAuth + Sell API)
# =====================================================================
# Required before any `scryland ebay-*` command. Start with sandbox if
# you're testing, then switch to production.

SCRYLAND_EBAY_ENVIRONMENT=production          # or `sandbox`

# From developer.ebay.com/my/keys for the selected environment.
SCRYLAND_EBAY_APP_ID=
SCRYLAND_EBAY_CERT_ID=
SCRYLAND_EBAY_DEV_ID=

# The RuName string (not a URL). Create one under "User Tokens" on your
# keyset. Any auth-accepted URL works since you'll paste the `code` back
# into the CLI manually.
SCRYLAND_EBAY_REDIRECT_URI_NAME=

# Populated by `scryland ebay-bootstrap`.
SCRYLAND_EBAY_FULFILLMENT_POLICY_ID=
SCRYLAND_EBAY_PAYMENT_POLICY_ID=
SCRYLAND_EBAY_RETURN_POLICY_ID=
SCRYLAND_EBAY_MERCHANT_LOCATION_KEY=default

# Passphrase for the stored eBay token file (set once with `ebay-auth`).
# Set to skip the prompt on every command.
SCRYLAND_EBAY_PASSPHRASE=

# Your eBay seller username — used to filter your own listings out of the
# Browse undercut search (so you don't compete with yourself). If unset,
# Scryland tries /identity (often 404 without the extra scope) and then
# falls back to looking you up via Browse on one of your live listings.
SCRYLAND_EBAY_SELLER_USERNAME=

# Shipping cost your buyers pay. Must match whatever your fulfillment
# policy actually charges — used for total-price undercut math. Run
# `scryland ebay-update-shipping --cost X.XX` to sync the policy if you
# change this.
SCRYLAND_EBAY_SHIPPING_COST=0.99
